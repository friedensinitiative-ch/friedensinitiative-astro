---
// src/components/home/MediaSection.astro
// YouTube embed + "Featured Video" label + two action buttons (More / Gallery).
import { useTranslations, type Locale } from '@i18n/index';
import { buildPath } from '@i18n/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const videoId = t('media.videoId');

const playlistUrl = 'https://www.youtube.com/watch?v=0VqiaQaG4uI&list=PLd2VIS0aIdOMSmmH-3Xvx3i3X3ma95SS8';
const galleryUrl = buildPath('gallery', locale);
---
<section class="bg-brand-parchment">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl mb-4">{t('media.title')}</h2>
    <p class="text-lg text-brand-ink-soft max-w-prose mb-8">{t('media.description')}</p>

    <p class="text-xs uppercase tracking-[0.25em] text-brand-gold-500 mb-3">
      {t('media.featuredVideo')}
    </p>
    <h3 class="font-serif text-xl md:text-2xl mb-4">{t('media.videoTitle')}</h3>

    <div class="relative w-full max-w-3xl rounded-lg overflow-hidden shadow-sm border border-brand-gold-100 bg-black" style="aspect-ratio: 16 / 9;">
      <iframe
        class="absolute inset-0 w-full h-full"
        src={`https://www.youtube-nocookie.com/embed/${videoId}`}
        title={t('media.videoTitle')}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <div class="mt-6 flex flex-wrap gap-3 max-w-3xl">
      <a
        href={playlistUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded border border-brand-gold-400 text-brand-gold-700 hover:bg-brand-gold-50 transition text-sm"
      >
        <span aria-hidden="true">▶</span> {t('media.moreVideos')}
      </a>
      <a
        href={galleryUrl}
        class="inline-flex items-center gap-2 px-4 py-2 rounded border border-brand-gold-400 text-brand-gold-700 hover:bg-brand-gold-50 transition text-sm"
      >
        <span aria-hidden="true">🖼</span> {t('media.photoGallery')}
      </a>
    </div>
  </div>
</section>
