---
// src/components/donate/DonateTwint.astro
// TWINT QR with merchant code from public/uploads/twint-qr.png
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="card-soft my-8">
  <h2 class="text-2xl mb-6 flex items-center gap-3">
    <span aria-hidden="true">📱</span>
    {t('donate.twint.title')}
  </h2>

  <div class="grid md:grid-cols-[auto_1fr] gap-8 items-center">
    <img
      src="/uploads/twint-qr.png"
      alt="TWINT QR"
      width="160"
      height="160"
      loading="lazy"
      class="w-40 h-40 rounded bg-white border border-brand-gold-100"
    />

    <ol class="space-y-3 text-base">
      <li class="flex gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-gold-100 text-brand-gold-700 flex items-center justify-center text-sm font-medium">1</span>
        <span>{t('donate.twint.step1')}</span>
      </li>
      <li class="flex gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-gold-100 text-brand-gold-700 flex items-center justify-center text-sm font-medium">2</span>
        <span>{t('donate.twint.step2')}</span>
      </li>
    </ol>
  </div>

  <p class="mt-6 text-sm text-brand-ink-soft">
    {t('donate.twint.fallback')}
  </p>
</section>
