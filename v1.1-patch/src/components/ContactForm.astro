---
// src/components/ContactForm.astro
// -----------------------------------------------------------------------------
// Native Netlify Forms integration.
//
// Why this is set up the way it is:
//
// 1. Netlify scans the BUILT HTML at deploy time to detect forms. It needs to
//    find a <form> with both `name="..."` and a hidden `<input name="form-name">`
//    matching that name. If form-name is missing, submissions return 404.
//
// 2. Astro's HTML output can strip "unused" hidden inputs in some cases. To be
//    safe we also ship a static detection form at /public/__forms.html that
//    lists all our form names so Netlify always sees them at deploy time.
//
// 3. We set action="/{locale-slug-for-thanks}/" so Netlify redirects users to
//    our localised thank-you page after a successful POST instead of falling
//    back to its default success page (which 404s because of trailing-slash
//    mismatches with Astro-generated routes).
//
// 4. Submissions appear in the Netlify dashboard under "Forms" and (optionally)
//    trigger email notifications: Site settings → Forms → Form notifications.
// -----------------------------------------------------------------------------
import { useTranslations, type Locale } from '@i18n/index';
import { buildPath } from '@i18n/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const thanksPath = buildPath('thanks', locale);
const formName = `contact-${locale}`;

const subjectOptions: { value: string; key: string }[] = [
  { value: 'general',    key: 'general' },
  { value: 'donation',   key: 'donation' },
  { value: 'volunteer',  key: 'volunteer' },
  { value: 'media',      key: 'media' },
  { value: 'other',      key: 'other' },
];
---
<form
  name={formName}
  method="POST"
  action={thanksPath}
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  class="space-y-5"
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="hidden">
    <label>Don't fill this out if you're human: <input name="bot-field" /></label>
  </p>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-name">
      {t('contact.form.name')} *
    </label>
    <input
      id="contact-name"
      name="name"
      type="text"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    />
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-email">
      {t('contact.form.email')} *
    </label>
    <input
      id="contact-email"
      name="email"
      type="email"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    />
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-subject">
      {t('contact.form.subject')} *
    </label>
    <select
      id="contact-subject"
      name="subject"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    >
      <option value="">{t('contact.subjectOptions.placeholder')}</option>
      {subjectOptions.map((opt) => (
        <option value={opt.value}>{t(`contact.subjectOptions.${opt.key}`)}</option>
      ))}
    </select>
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-message">
      {t('contact.form.message')} *
    </label>
    <textarea
      id="contact-message"
      name="message"
      rows="6"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    ></textarea>
  </div>

  <button
    type="submit"
    class="px-6 py-2.5 bg-brand-gold-400 text-white rounded font-medium hover:bg-brand-gold-500 transition"
  >
    {t('contact.form.send')}
  </button>
</form>
