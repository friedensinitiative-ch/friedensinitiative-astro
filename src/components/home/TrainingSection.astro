---
// src/components/home/TrainingSection.astro
// Three paragraphs about how Vedic Pandits are systematically trained.
import { useTranslations, renderHighlight, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="bg-white">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24">
    <h2
      class="text-3xl md:text-4xl mb-8 max-w-prose"
      set:html={renderHighlight(t('training.title'))}
    />
    <div class="space-y-5 text-lg text-brand-ink-soft max-w-prose">
      <p>{t('training.paragraph1')}</p>
      <p>{t('training.paragraph2')}</p>
      <p>{t('training.paragraph3')}</p>
    </div>
  </div>
</section>
