---
// src/components/home/MediaSection.astro
// Photo/media section. Uses public/images/yagya-ceremony.jpg if present.
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="bg-brand-parchment">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24">
    <h2 class="text-3xl md:text-4xl mb-4">{t('media.title')}</h2>
    <p class="text-lg text-brand-ink-soft max-w-prose mb-8">{t('media.description')}</p>

    <figure class="rounded-lg overflow-hidden shadow-sm border border-brand-gold-100">
      <img
        src="/images/yagya-ceremony.jpg"
        alt={t('media.videoTitle')}
        loading="lazy"
        class="w-full h-auto object-cover"
      />
      <figcaption class="bg-white px-4 py-3 text-sm text-brand-ink-muted">
        {t('media.videoTitle')}
      </figcaption>
    </figure>
  </div>
</section>
