---
// src/components/donate/DonateHero.astro
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="bg-gradient-to-b from-brand-parchment to-white">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24 text-center">
    <h1 class="text-4xl md:text-5xl mb-4">{t('donate.hero.title')}</h1>
    <p class="text-xl text-brand-gold-500">{t('donate.hero.subtitle')}</p>
  </div>
</section>
