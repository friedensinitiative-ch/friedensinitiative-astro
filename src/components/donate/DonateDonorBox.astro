---
// src/components/donate/DonateDonorBox.astro
// -----------------------------------------------------------------------------
// DonorBox embed for credit card donations.
//
// PLACEHOLDER: Replace `DONORBOX_FORM_ID` below with the actual form ID once
// retrieved from Mailchimp/old repo. The DonorBox documentation describes
// how to find it in the embed code under their dashboard.
//
// Typical embed snippet looks like:
//   <script src="https://donorbox.org/widget.js" paypalExpress="false"></script>
//   <iframe src="https://donorbox.org/embed/FORM_ID" ... ></iframe>
// -----------------------------------------------------------------------------
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
  /** DonorBox form ID (e.g. 'frieden-spenden'). Pass empty for placeholder. */
  formId?: string;
}

const { locale, formId = '' } = Astro.props;
const t = useTranslations(locale);
---
<section class="my-8">
  <div class="bg-brand-gold-50 border-t-4 border-brand-gold-400 rounded-t-lg px-6 py-4">
    <h2 class="text-2xl flex items-center gap-3">
      <span aria-hidden="true">💳</span>
      {t('donate.creditcard.title')}
    </h2>
  </div>

  <div class="border border-brand-gold-100 rounded-b-lg p-6 bg-white">
    {formId ? (
      <iframe
        src={`https://donorbox.org/embed/${formId}`}
        name="donorbox"
        seamless={true}
        scrolling="no"
        height="900px"
        width="100%"
        style="max-width: 600px; min-width: 250px; max-height: none !important; margin: 0 auto; display: block;"
        allow="payment"
        title="DonorBox donation form"
      ></iframe>
    ) : (
      <div class="text-center py-12 text-brand-ink-muted text-sm border-2 border-dashed border-brand-gold-200 rounded bg-brand-gold-50/30">
        <p class="font-medium mb-1">DonorBox Widget</p>
        <p>(Form-ID wird nach Bereitstellung eingetragen)</p>
      </div>
    )}
  </div>
</section>
