---
// src/components/donate/DonateImpactCards.astro
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const cards = [
  { key: 'why',    icon: '🌱' },
  { key: 'how',    icon: '🔍' },
  { key: 'global', icon: '🌍' },
];
---
<div class="grid md:grid-cols-3 gap-4 my-12">
  {cards.map((card) => (
    <div class="card-soft text-center">
      <div class="text-3xl mb-3" aria-hidden="true">{card.icon}</div>
      <h3 class="text-xl mb-2">{t(`donate.impact.${card.key}.title`)}</h3>
      <p class="text-sm text-brand-ink-soft">{t(`donate.impact.${card.key}.text`)}</p>
    </div>
  ))}
</div>
