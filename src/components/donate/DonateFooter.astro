---
// src/components/donate/DonateFooter.astro
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<div class="my-8 p-6 rounded-lg bg-brand-gold-50/50 text-center">
  <p class="text-base text-brand-ink-soft">
    <span class="text-brand-gold-500 mr-2" aria-hidden="true">💛</span>
    {t('donate.footer.volunteer')}
  </p>
  <p class="mt-2 text-sm">
    <a href={`mailto:${t('donate.footer.contact')}`} class="text-brand-gold-600 hover:text-brand-gold-700 underline">
      {t('donate.footer.contact')}
    </a>
  </p>
</div>

<p class="text-xs text-brand-ink-muted bg-brand-gold-50/30 rounded p-4 my-8">
  {t('donate.footer.tax')}
</p>
