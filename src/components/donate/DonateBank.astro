---
// Bank transfer — Mailchimp-style layout.
// QR code on the left, bank details as natural text on the right.
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="my-12">
  <h2 class="text-center text-xl md:text-2xl font-semibold text-brand-gold-700 uppercase tracking-wide mb-6">
    {t('donate.bank.title')}
  </h2>

  <p class="text-base text-brand-ink-soft mb-8 max-w-3xl mx-auto">
    {t('donate.bank.intro')}
  </p>

  <div class="grid md:grid-cols-[auto_1fr] gap-8 md:gap-12 items-start max-w-3xl mx-auto">
    <div class="flex flex-col items-center">
      <img
        src="/uploads/swiss-qr.png"
        alt="Swiss QR-Bill"
        width="180"
        height="180"
        loading="lazy"
        class="w-44 h-44 border border-brand-gold-100 rounded bg-white"
      />
      <p class="text-xs text-brand-ink-muted mt-2 text-center max-w-[10rem]">
        {t('donate.bank.qrCaption')}
      </p>
    </div>

    <div class="text-base text-brand-ink-soft">
      <p class="font-semibold mb-4 leading-relaxed">
        {t('donate.bank.heading')}
      </p>
      <div class="space-y-1 font-mono text-sm">
        <p>{t('donate.bank.recipientValue')}</p>
        <p>{t('donate.bank.ibanLabel')}: {t('donate.bank.ibanValue')}</p>
        <p>{t('donate.bank.bicLabel')}: {t('donate.bank.bicValue')}</p>
      </div>
    </div>
  </div>
</section>
