---
// src/components/donate/DonateBank.astro
// -----------------------------------------------------------------------------
// Bank transfer section — highlighted with gold border as preferred method.
// Contains the Swiss QR code placeholder. Replace /uploads/bank-qr.png with
// the actual generated Swiss QR-bill image.
// -----------------------------------------------------------------------------
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="card-gold my-8">
  <h2 class="text-2xl mb-6 flex items-center gap-3">
    <span class="text-brand-gold-400" aria-hidden="true">⭐</span>
    {t('donate.bank.title')}
  </h2>

  <div class="grid md:grid-cols-[1fr_auto] gap-8 items-start">
    <dl class="space-y-3 text-base">
      <div>
        <dt class="text-sm text-brand-ink-muted uppercase tracking-wide">{t('donate.bank.recipient')}</dt>
        <dd class="font-medium">{t('donate.bank.recipientValue')}</dd>
      </div>
      <div>
        <dt class="text-sm text-brand-ink-muted uppercase tracking-wide">{t('donate.bank.iban')}</dt>
        <dd class="font-mono">{t('donate.bank.ibanValue')}</dd>
      </div>
      <div>
        <dt class="text-sm text-brand-ink-muted uppercase tracking-wide">{t('donate.bank.bic')}</dt>
        <dd class="font-mono">{t('donate.bank.bicValue')}</dd>
      </div>
    </dl>

    <div class="flex flex-col items-center">
      <!-- Swiss QR-bill placeholder. Replace with actual QR image. -->
      <div
        class="w-40 h-40 border-2 border-dashed border-brand-gold-300 rounded flex items-center justify-center text-xs text-center text-brand-ink-muted bg-brand-gold-50"
        role="img"
        aria-label="Swiss QR Bill placeholder"
      >
        Swiss QR-Bill<br/>(Platzhalter)
      </div>
      <p class="text-xs text-brand-ink-muted mt-2 text-center max-w-[10rem]">
        Mit Banking-App scannen
      </p>
    </div>
  </div>

  <p class="mt-6 pt-4 border-t border-brand-gold-100 text-sm text-brand-gold-700 flex items-center gap-2">
    <span aria-hidden="true">💡</span>
    {t('donate.bank.note')}
  </p>
</section>
