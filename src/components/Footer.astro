---
// src/components/Footer.astro
// Footer with logo, imprint/privacy links, social media, copyright, trademark.
import { useTranslations, type Locale } from '@i18n/index';
import { buildPath } from '@i18n/routes';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---
<footer class="border-t border-brand-gold-200/50 mt-16 bg-white/60">
  <div class="max-w-content mx-auto px-4 py-10 space-y-6">

    <!-- Logo line -->
    <div class="flex justify-center items-center gap-2 text-brand-ink">
      <Logo height={24} />
      <span class="font-serif text-lg">Globale Friedensinitiative Schweiz</span>
    </div>

    <!-- Page links -->
    <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
      <a href={buildPath('imprint', locale)} class="text-brand-ink-muted hover:text-brand-gold-500">{t('footer.imprint')}</a>
      <a href={buildPath('privacy', locale)} class="text-brand-ink-muted hover:text-brand-gold-500">{t('footer.privacy')}</a>
      <a href={buildPath('contact', locale)} class="text-brand-ink-muted hover:text-brand-gold-500">{t('nav.contact')}</a>
    </div>

    <!-- Social icons -->
    <div class="flex justify-center gap-4 text-brand-ink-muted">
      <a
        href="https://www.youtube.com/watch?v=0VqiaQaG4uI&list=PLd2VIS0aIdOMSmmH-3Xvx3i3X3ma95SS8"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-gold-500 transition"
        aria-label="YouTube"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a
        href="https://www.facebook.com/VedicPandits"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-gold-500 transition"
        aria-label="Facebook"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <a
        href="https://twitter.com/GlobalPeaceIni"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand-gold-500 transition"
        aria-label="Twitter / X"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>

    <p class="text-center text-sm text-brand-ink-muted pt-2">
      {t('footer.copyright').replace('{{year}}', String(year))}
    </p>

    <p class="text-xs text-brand-ink-muted/80 text-center max-w-3xl mx-auto leading-relaxed">
      {t('footer.trademark')}
    </p>
  </div>
</footer>
