---
// src/components/ResponsiveImage.astro
// -----------------------------------------------------------------------------
// Responsive image with WebP preferred, JPG fallback, two-resolution srcset
// for retina screens, native lazy loading.
//
// Expects files at:
//   /images/{slug}-w800.webp
//   /images/{slug}-w1600.webp
//   /images/{slug}.jpg              (fallback for older browsers)
//
// Usage:
//   <ResponsiveImage slug="training" alt="..." aspectRatio="3/2" />
// -----------------------------------------------------------------------------

interface Props {
  slug: string;
  alt: string;
  /** CSS aspect-ratio (e.g. "3/2", "4/3", "16/9") — keeps layout stable while loading */
  aspectRatio?: string;
  /** Tailwind classes for the wrapping figure */
  class?: string;
  /** Tailwind classes for the inner img */
  imgClass?: string;
  /** Set eager loading for above-the-fold images (e.g. hero) */
  eager?: boolean;
}

const {
  slug,
  alt,
  aspectRatio = '3/2',
  class: className = '',
  imgClass = '',
  eager = false,
} = Astro.props;
---
<figure class={`overflow-hidden ${className}`} style={`aspect-ratio: ${aspectRatio};`}>
  <picture>
    <source
      type="image/webp"
      srcset={`/images/${slug}-w800.webp 800w, /images/${slug}-w1600.webp 1600w`}
      sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 800px"
    />
    <img
      src={`/images/${slug}.jpg`}
      alt={alt}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      class={`w-full h-full object-cover ${imgClass}`}
    />
  </picture>
</figure>
