---
// src/components/ContactForm.astro
// -----------------------------------------------------------------------------
// Native Netlify Forms integration with AJAX submit fallback.
//
// Why AJAX submit:
// Netlify''s serving layer transforms HTML at serve time and strips the hidden
// <input name="form-name"> from forms it detects as Netlify Forms. Without
// form-name in the POST body, Netlify can''t identify the form and falls back
// to its generic English "Thank you!" page instead of redirecting to our
// localised /danke route.
//
// The inline script below intercepts the form submit, builds the POST body
// explicitly (with form-name set), sends it via fetch, and on success
// navigates the browser to our custom thanks page.
// -----------------------------------------------------------------------------
import { useTranslations, type Locale } from ''@i18n/index'';
import { buildPath } from ''@i18n/routes'';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const thanksPath = buildPath(''thanks'', locale);
const formName = `contact-${locale}`;

const subjectOptions: { value: string; key: string }[] = [
  { value: ''general'',    key: ''general'' },
  { value: ''donation'',   key: ''donation'' },
  { value: ''volunteer'',  key: ''volunteer'' },
  { value: ''media'',      key: ''media'' },
  { value: ''other'',      key: ''other'' },
];
---
<form
  name={formName}
  method="POST"
  action={thanksPath}
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  class="space-y-5"
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="hidden">
    <label>Don''t fill this out if you''re human: <input name="bot-field" /></label>
  </p>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-name">
      {t(''contact.form.name'')} *
    </label>
    <input
      id="contact-name"
      name="name"
      type="text"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    />
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-email">
      {t(''contact.form.email'')} *
    </label>
    <input
      id="contact-email"
      name="email"
      type="email"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    />
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-subject">
      {t(''contact.form.subject'')} *
    </label>
    <select
      id="contact-subject"
      name="subject"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    >
      <option value="">{t(''contact.subjectOptions.placeholder'')}</option>
      {subjectOptions.map((opt) => (
        <option value={opt.value}>{t(`contact.subjectOptions.${opt.key}`)}</option>
      ))}
    </select>
  </div>

  <div>
    <label class="block mb-1 text-sm font-medium text-brand-ink-soft" for="contact-message">
      {t(''contact.form.message'')} *
    </label>
    <textarea
      id="contact-message"
      name="message"
      rows="6"
      required
      class="w-full px-3 py-2 border border-brand-gold-200 rounded focus:border-brand-gold-400 focus:outline-none focus:ring-1 focus:ring-brand-gold-400 bg-white"
    ></textarea>
  </div>

  <button
    type="submit"
    class="px-6 py-2.5 bg-brand-gold-400 text-white rounded font-medium hover:bg-brand-gold-500 transition"
  >
    {t(''contact.form.send'')}
  </button>
</form>

<script is:inline define:vars={{ formName, thanksPath }}>
  // AJAX submit to bypass Netlify''s HTML serve-time transformation.
  const form = document.querySelector(`form[name="${formName}"]`);
  if (form) {
    form.addEventListener(''submit'', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      formData.set(''form-name'', formName);

      const button = form.querySelector(''button[type="submit"]'');
      const originalText = button ? button.textContent : '''';
      if (button) {
        button.disabled = true;
        button.textContent = ''...'';
      }

      try {
        const response = await fetch(''/'', {
          method: ''POST'',
          headers: { ''Content-Type'': ''application/x-www-form-urlencoded'' },
          body: new URLSearchParams(formData).toString(),
        });

        if (response.ok) {
          window.location.href = thanksPath;
        } else {
          alert(''Submission failed ('' + response.status + ''). Please try again or email us directly at info@friedensinitiative.ch.'');
          if (button) { button.disabled = false; button.textContent = originalText; }
        }
      } catch (err) {
        alert(''Submission failed: '' + err.message + ''. Please try again or email us directly at info@friedensinitiative.ch.'');
        if (button) { button.disabled = false; button.textContent = originalText; }
      }
    });
  }
</script>
