---
// src/components/PhotoGallery.astro
// -----------------------------------------------------------------------------
// Responsive photo grid + lightbox, grouped into stacked category sections.
//
// - Images carry a `category` (maharishi | pandits | kongo). Each category is
//   rendered as its own <section> with a localized heading; one shared lightbox
//   spans all images (prev/next walks the whole set across sections).
// - Standard images live at /images/gallery/{slug}-w{400,800,1600}.webp + .jpg.
// - An image may instead provide a single `src` (one webp, no responsive
//   variants) — used for the Congo photos until variants are generated (v1.4).
// - Grid: 2 cols (mobile) / 3 (tablet) / 4 (desktop); tiles load the 400w thumb
//   (or the single `src`). Lightbox: dark backdrop, 800w/1600w srcset (or `src`),
//   arrow keys / swipe / buttons / Esc, ARIA labels, focus management.
// -----------------------------------------------------------------------------
import galleryData from '../data/gallery.json';

interface Labels {
  closeLabel: string;
  prevLabel: string;
  nextLabel: string;
  counter: string; // "{current} of {total}"
}

interface Props {
  /** Localized strings for ARIA / counter */
  labels: Labels;
  /** Localized section headings, keyed by category */
  headings: { maharishi: string; pandits: string; kongo: string };
}

type GalleryImage = {
  slug: string;
  caption: string;
  aspectRatio: string;
  category?: string;
  src?: string;
};

const { labels, headings } = Astro.props;
const images = galleryData as GalleryImage[];

// Keep each image's global index (for the shared lightbox) while grouping.
const indexed = images.map((img, i) => ({ ...img, i }));

const categories: { key: 'maharishi' | 'pandits' | 'kongo'; title: string }[] = [
  { key: 'maharishi', title: headings.maharishi },
  { key: 'pandits', title: headings.pandits },
  { key: 'kongo', title: headings.kongo },
];

const sections = categories
  .map((c) => ({ ...c, items: indexed.filter((img) => img.category === c.key) }))
  .filter((s) => s.items.length > 0);
---

{sections.map((section) => (
  <section class="my-10 md:my-14">
    <h2 class="text-2xl md:text-3xl mb-6 text-brand-gold-700">{section.title}</h2>
    <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 md:gap-3 list-none p-0">
      {section.items.map((img) => (
        <li class="m-0">
          <button
            type="button"
            class="gallery-tile group block w-full overflow-hidden rounded-md bg-brand-parchment border border-brand-gold-100 hover:border-brand-gold-300 transition focus:outline-none focus:ring-2 focus:ring-brand-gold-400"
            style="aspect-ratio: 1 / 1;"
            data-index={img.i}
            aria-label={img.caption}
          >
            {img.src ? (
              <img
                src={img.src}
                alt={img.caption}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
              />
            ) : (
              <picture>
                <source type="image/webp" srcset={`/images/gallery/${img.slug}-w400.webp`} />
                <img
                  src={`/images/gallery/${img.slug}.jpg`}
                  alt={img.caption}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                />
              </picture>
            )}
          </button>
        </li>
      ))}
    </ul>
  </section>
))}

<!-- Lightbox: hidden by default -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden bg-black/95 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <!-- Close button -->
  <button
    id="lightbox-close"
    type="button"
    class="absolute top-4 right-4 z-10 p-2 rounded text-white/80 hover:text-white hover:bg-white/10 transition"
    aria-label={labels.closeLabel}
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <!-- Prev / Next -->
  <button
    id="lightbox-prev"
    type="button"
    class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-10 p-3 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition"
    aria-label={labels.prevLabel}
  >
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button
    id="lightbox-next"
    type="button"
    class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-10 p-3 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition"
    aria-label={labels.nextLabel}
  >
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  <!-- Image container -->
  <div class="absolute inset-0 flex flex-col items-center justify-center px-4 py-16 md:py-12">
    <div id="lightbox-image-wrap" class="flex-1 flex items-center justify-center max-w-7xl w-full min-h-0">
      <picture id="lightbox-picture" class="block max-w-full max-h-full">
        <source id="lightbox-source" type="image/webp" />
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="max-w-full max-h-[80vh] object-contain rounded-md shadow-2xl"
        />
      </picture>
    </div>

    <!-- Caption + counter -->
    <div class="mt-4 text-center max-w-3xl">
      <p id="lightbox-caption" class="text-white text-sm md:text-base mb-1"></p>
      <p id="lightbox-counter" class="text-white/50 text-xs"></p>
    </div>
  </div>
</div>

<script define:vars={{ images: images, counterTemplate: labels.counter }}>
  const tiles = document.querySelectorAll('.gallery-tile');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxSource = document.getElementById('lightbox-source');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const btnClose = document.getElementById('lightbox-close');
  const btnPrev = document.getElementById('lightbox-prev');
  const btnNext = document.getElementById('lightbox-next');

  let currentIndex = 0;
  let triggerElement = null; // For restoring focus

  function showImage(index) {
    currentIndex = ((index % images.length) + images.length) % images.length;
    const img = images[currentIndex];
    if (img.src) {
      // Single webp, no responsive variants.
      lightboxSource.srcset = '';
      lightboxSource.removeAttribute('sizes');
      lightboxImg.src = img.src;
    } else {
      lightboxSource.srcset = `/images/gallery/${img.slug}-w800.webp 800w, /images/gallery/${img.slug}-w1600.webp 1600w`;
      lightboxSource.sizes = '90vw';
      lightboxImg.src = `/images/gallery/${img.slug}.jpg`;
    }
    lightboxImg.alt = img.caption;
    lightboxCaption.textContent = img.caption;
    lightboxCounter.textContent = counterTemplate
      .replace('{current}', String(currentIndex + 1))
      .replace('{total}', String(images.length));
  }

  function openLightbox(index, trigger) {
    triggerElement = trigger;
    showImage(index);
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.style.overflow = '';
    if (triggerElement) triggerElement.focus();
  }

  function prevImage() { showImage(currentIndex - 1); }
  function nextImage() { showImage(currentIndex + 1); }

  tiles.forEach((tile) => {
    tile.addEventListener('click', () => {
      const idx = parseInt(tile.dataset.index, 10);
      openLightbox(idx, tile);
    });
  });

  btnClose.addEventListener('click', closeLightbox);
  btnPrev.addEventListener('click', prevImage);
  btnNext.addEventListener('click', nextImage);

  // Click on backdrop (but not on inner controls) closes
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') { e.preventDefault(); closeLightbox(); }
    else if (e.key === 'ArrowLeft') { e.preventDefault(); prevImage(); }
    else if (e.key === 'ArrowRight') { e.preventDefault(); nextImage(); }
  });

  // Swipe gestures on touch devices
  let touchStartX = 0;
  let touchEndX = 0;
  lightbox.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  lightbox.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchEndX - touchStartX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) prevImage();
      else nextImage();
    }
  }, { passive: true });
</script>
