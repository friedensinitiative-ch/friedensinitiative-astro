---
// src/components/Hero.astro
// -----------------------------------------------------------------------------
// Hero with subtle mandala (sacred geometry) background and ornamental
// divider between title and description, inherited from the original React
// site's visual language.
// -----------------------------------------------------------------------------
import { useTranslations, renderHighlight, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="relative overflow-hidden bg-gradient-to-b from-brand-parchment to-white">

  <!-- Sacred geometry mandala backdrop -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <svg
      viewBox="0 0 400 400"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      class="w-[120vw] max-w-[900px] opacity-[0.06]"
      aria-hidden="true"
    >
      <circle cx="200" cy="200" r="180" stroke="#D4AF37" stroke-width="0.5" />
      <circle cx="200" cy="200" r="150" stroke="#D4AF37" stroke-width="0.5" />
      <circle cx="200" cy="200" r="120" stroke="#D4AF37" stroke-width="0.5" />
      <circle cx="200" cy="200" r="90"  stroke="#D4AF37" stroke-width="0.5" />
      <!-- 8 axes -->
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(22.5 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(45 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(67.5 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(90 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(112.5 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(135 200 200)" />
      <line x1="200" y1="20" x2="200" y2="380" stroke="#D4AF37" stroke-width="0.4" transform="rotate(157.5 200 200)" />
    </svg>
  </div>

  <!-- Hero content -->
  <div class="relative z-10 max-w-content mx-auto px-4 py-20 md:py-28 text-center">
    <p class="text-sm uppercase tracking-[0.3em] text-brand-gold-500 mb-6">
      {t('hero.subtitle')}
    </p>

    <h1
      class="text-4xl md:text-5xl lg:text-6xl mb-8 leading-tight"
      set:html={renderHighlight(t('hero.title'))}
    />

    <!-- Ornamental divider: gold line · diamond · gold line -->
    <div class="flex items-center justify-center mb-8" aria-hidden="true">
      <div class="w-16 md:w-24 h-px bg-gradient-to-r from-transparent via-brand-gold-400 to-transparent"></div>
      <div class="w-2 h-2 mx-3 rotate-45 border border-brand-gold-400"></div>
      <div class="w-16 md:w-24 h-px bg-gradient-to-r from-transparent via-brand-gold-400 to-transparent"></div>
    </div>

    <p class="text-lg md:text-xl text-brand-ink-soft max-w-prose mx-auto leading-relaxed">
      {t('hero.description')}
    </p>

    <a
      href="#training"
      class="inline-flex items-center gap-2 mt-12 text-xs uppercase tracking-[0.25em] text-brand-ink-muted hover:text-brand-gold-500 transition"
    >
      <span>↓</span> {t('hero.scrollDown')}
    </a>
  </div>
</section>
