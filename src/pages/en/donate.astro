---
// src/pages/en/donate.astro – English donation page
import { getEntry } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import DonateHero from '@components/donate/DonateHero.astro';
import DonateImpactCards from '@components/donate/DonateImpactCards.astro';
import DonateBank from '@components/donate/DonateBank.astro';
import DonateTwint from '@components/donate/DonateTwint.astro';
import DonateDonorBox from '@components/donate/DonateDonorBox.astro';
import DonateFooter from '@components/donate/DonateFooter.astro';
import { useTranslations } from '@i18n/index';

const locale = 'en' as const;
const t = useTranslations(locale);

const donateContent = await getEntry('donate', 'en');
const { Content: DonateProse } = await donateContent.render();
---
<PageLayout
  {locale}
  title={`${t('donate.hero.title')} – ${t('hero.subtitle')}`}
  description={t('donate.hero.subtitle')}
  route="donate"
>
  <DonateHero {locale} />

  <div class="max-w-content mx-auto px-4 py-8">
    <article class="prose prose-lg max-w-prose mx-auto text-brand-ink-soft mb-12">
      <DonateProse />
    </article>

    <DonateImpactCards {locale} />

    <DonateBank {locale} />
    <DonateTwint {locale} />
    <DonateDonorBox {locale} />

    <DonateFooter {locale} />
  </div>
</PageLayout>
