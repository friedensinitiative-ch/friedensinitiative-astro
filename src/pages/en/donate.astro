---
import PageLayout from '@layouts/PageLayout.astro';
import DonateBank from '@components/donate/DonateBank.astro';
import DonateTwint from '@components/donate/DonateTwint.astro';
import DonateDonorBox from '@components/donate/DonateDonorBox.astro';
import { useTranslations } from '@i18n/index';

const locale = 'en' as const;
const t = useTranslations(locale);
---
<PageLayout
  {locale}
  title={`${t('donate.hero.title')} – ${t('nav.donate')}`}
  description={t('donate.hero.subtitle')}
  route="donate"
>
  <section class="bg-gradient-to-b from-brand-parchment to-white">
    <div class="max-w-content mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl mb-4">{t('donate.hero.title')}</h1>
      <p class="text-xl text-brand-gold-500 max-w-prose mx-auto">{t('donate.hero.subtitle')}</p>
    </div>
  </section>

  <div class="max-w-content mx-auto px-4 py-6">
    <p class="text-base text-brand-ink-soft mb-12 max-w-3xl mx-auto text-center">
      {t('donate.intro')}
    </p>

    <hr class="border-t-2 border-brand-gold-400 max-w-3xl mx-auto" />
    <DonateBank {locale} />
    <hr class="border-t-2 border-brand-gold-400 max-w-3xl mx-auto" />
    <DonateTwint {locale} />
    <hr class="border-t-2 border-brand-gold-400 max-w-3xl mx-auto" />
    <DonateDonorBox {locale} />
    <hr class="border-t-2 border-brand-gold-400 max-w-3xl mx-auto" />

    <div class="mt-10 mb-4 text-center max-w-3xl mx-auto space-y-4 text-sm text-brand-ink-soft">
      <p class="flex items-center justify-center gap-2">
        <span aria-hidden="true">💛</span>
        {t('donate.footer.volunteer')}
      </p>
      <p>
        <a href={`mailto:${t('donate.footer.contact')}`}
           class="text-brand-gold-600 hover:text-brand-gold-700 underline">
          {t('donate.footer.contact')}
        </a>
      </p>
      <p class="text-xs text-brand-ink-muted">
        {t('donate.footer.tax')}
      </p>
    </div>
  </div>
</PageLayout>
