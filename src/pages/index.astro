---
// Home page for locale: de — overview of the peace projects.
import PageLayout from '@layouts/PageLayout.astro';
import Hero from '@components/Hero.astro';
import IntroStats from '@components/home/IntroStats.astro';
import ProjectCards from '@components/ProjectCards.astro';
import ScienceOfPeace from '@components/ScienceOfPeace.astro';
import { useTranslations } from '@i18n/index';

const locale = 'de' as const;
const t = useTranslations(locale);
---
<PageLayout
  {locale}
  title={`${t('home.hero.eyebrow')} – ${t('home.hero.title').replace(/\{\{highlight\}\}|\{\{\/highlight\}\}/g, '')}`}
  description={t('home.hero.subtitle')}
  route="home"
>
  <Hero {locale} />
  <IntroStats {locale} />
  <ProjectCards {locale} />
  <ScienceOfPeace {locale} />
</PageLayout>
