---
import PageLayout from '@layouts/PageLayout.astro';
import PhotoGallery from '@components/PhotoGallery.astro';
import { useTranslations } from '@i18n/index';

const locale = 'de' as const;
const t = useTranslations(locale);

const labels = {
  closeLabel: t('gallery.closeLabel'),
  prevLabel: t('gallery.prevLabel'),
  nextLabel: t('gallery.nextLabel'),
  counter: t('gallery.counter'),
};

const headings = {
  maharishi: t('gallery.sections.maharishi'),
  pandits: t('gallery.sections.pandits'),
  kongo: t('gallery.sections.kongo'),
};
---
<PageLayout
  {locale}
  title={`${t('gallery.hero.title')} – ${t('gallery.hero.subtitle')}`}
  description={t('gallery.hero.subtitle')}
  route="gallery"
>
  <section class="bg-gradient-to-b from-brand-parchment to-white">
    <div class="max-w-content mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl mb-4">{t('gallery.hero.title')}</h1>
      <p class="text-xl text-brand-gold-500 max-w-prose mx-auto">{t('gallery.hero.subtitle')}</p>
    </div>
  </section>

  <div class="max-w-content mx-auto px-4 py-6">
    <p class="text-base text-brand-ink-soft max-w-prose mb-8">{t('gallery.intro')}</p>
    <PhotoGallery {labels} {headings} />
  </div>
</PageLayout>
