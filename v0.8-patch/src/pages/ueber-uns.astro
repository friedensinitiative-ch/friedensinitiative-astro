---
import PageLayout from '@layouts/PageLayout.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import { useTranslations } from '@i18n/index';

const locale = 'de' as const;
const t = useTranslations(locale);

const sections = ['earlyLife', 'teaching', 'vedicScience', 'peaceInitiative'] as const;
---
<PageLayout
  {locale}
  title={`${t('about.hero.title')} – ${t('nav.about')}`}
  description={t('about.hero.subtitle')}
  route="about"
>
  <section class="bg-gradient-to-b from-brand-parchment to-white">
    <div class="max-w-content mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl mb-4">{t('about.hero.title')}</h1>
      <p class="text-xl text-brand-gold-500 max-w-prose mx-auto">{t('about.hero.subtitle')}</p>
    </div>
  </section>

  <div class="max-w-content mx-auto px-4 py-12">

    <!-- Maharishi portrait + intro -->
    <div class="grid md:grid-cols-[2fr_3fr] gap-8 md:gap-12 items-start mb-12">
      <ResponsiveImage
        slug="maharishi"
        alt="Maharishi Mahesh Yogi"
        aspectRatio="3/2"
        class="rounded-lg shadow-sm border border-brand-gold-100"
        eager={true}
      />
      <p class="text-lg text-brand-ink-soft">{t('about.intro')}</p>
    </div>

    <div class="space-y-10">
      {sections.map((key) => (
        <section class="max-w-prose">
          <h2 class="text-2xl md:text-3xl mb-3 text-brand-gold-700">
            {t(`about.sections.${key}.title`)}
          </h2>
          <p class="text-lg text-brand-ink-soft">
            {t(`about.sections.${key}.text`)}
          </p>
        </section>
      ))}
    </div>

    <!-- Swiss legal/organizational section -->
    <section class="mt-16 pt-12 border-t border-brand-gold-200/50">
      <h2 class="text-2xl md:text-3xl mb-2">{t('about.swiss.title')}</h2>
      <p class="text-brand-gold-500 mb-6">{t('about.swiss.subtitle')}</p>

      <div class="space-y-4 max-w-prose text-base text-brand-ink-soft">
        <p>{t('about.swiss.founding')}</p>
        <p>{t('about.swiss.legal')}</p>
        <p>{t('about.swiss.tax')}</p>
        <p class="font-mono text-sm text-brand-ink-muted">{t('about.swiss.uid')}</p>
      </div>

      <div class="mt-8 max-w-prose">
        <h3 class="text-lg font-medium mb-3 text-brand-gold-700">{t('about.swiss.docsTitle')}</h3>
        <a href="/uploads/statuten.pdf" class="text-brand-gold-600 hover:text-brand-gold-700 underline text-sm">
          ↓ {t('about.swiss.docsStatutes')}
        </a>
      </div>
    </section>
  </div>
</PageLayout>
