---
// src/components/home/TrainingSection.astro
// Training section with photo on the right (text-left layout on desktop).
import { useTranslations, renderHighlight, type Locale } from '@i18n/index';
import ResponsiveImage from '@components/ResponsiveImage.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section id="training" class="bg-white">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-10 md:gap-12 items-center">
      <div>
        <h2
          class="text-3xl md:text-4xl mb-6"
          set:html={renderHighlight(t('training.title'))}
        />
        <div class="space-y-5 text-lg text-brand-ink-soft">
          <p>{t('training.paragraph1')}</p>
          <p>{t('training.paragraph2')}</p>
          <p>{t('training.paragraph3')}</p>
        </div>
      </div>

      <ResponsiveImage
        slug="training"
        alt="Maharishi Vedic Pandit Students"
        aspectRatio="3/2"
        class="rounded-lg shadow-sm border border-brand-gold-100"
      />
    </div>
  </div>
</section>
