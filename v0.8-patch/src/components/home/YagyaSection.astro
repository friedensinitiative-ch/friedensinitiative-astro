---
// src/components/home/YagyaSection.astro
// Yagya section with reciting photo + stats cards.
import { useTranslations, renderHighlight, type Locale } from '@i18n/index';
import ResponsiveImage from '@components/ResponsiveImage.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="bg-white">
  <div class="max-w-content mx-auto px-4 py-16 md:py-24">

    <div class="grid md:grid-cols-2 gap-10 md:gap-12 items-center mb-10">
      <div>
        <h2
          class="text-3xl md:text-4xl mb-6"
          set:html={renderHighlight(t('yagya.title'))}
        />
        <div class="space-y-5 text-lg text-brand-ink-soft">
          <p>{t('yagya.paragraph1')}</p>
          <p>{t('yagya.paragraph2')}</p>
          <p>{t('yagya.paragraph3')}</p>
          <p>{t('yagya.paragraph4')}</p>
        </div>
      </div>

      <ResponsiveImage
        slug="yagya"
        alt="Maharishi Vedic Pandits Reciting"
        aspectRatio="3/2"
        class="rounded-lg shadow-sm border border-brand-gold-100"
      />
    </div>

    <!-- Stats cards -->
    <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mt-10">
      <div class="card-soft text-center">
        <div class="font-serif text-4xl text-brand-gold-500 mb-2">{t('yagya.stat1Number')}</div>
        <div class="text-sm uppercase tracking-widest text-brand-ink-muted">{t('yagya.stat1Label')}</div>
      </div>
      <div class="card-soft text-center">
        <div class="font-serif text-4xl text-brand-gold-500 mb-2">{t('yagya.stat2Number')}</div>
        <div class="text-sm uppercase tracking-widest text-brand-ink-muted">{t('yagya.stat2Label')}</div>
      </div>
    </div>
  </div>
</section>
