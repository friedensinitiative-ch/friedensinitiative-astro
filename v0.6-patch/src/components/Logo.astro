---
// src/components/Logo.astro
// -----------------------------------------------------------------------------
// Brand mark: a gold globe with longitude/latitude lines representing the
// "global" in Globale Friedensinitiative. Pure SVG, scales perfectly.
// -----------------------------------------------------------------------------

interface Props {
  size?: number;
  /** Override the gold colour — defaults to the brand palette gold-400 */
  color?: string;
  /** Tailwind classes applied to the wrapping span */
  class?: string;
}

const { size = 32, color = '#D4AF37', class: className = '' } = Astro.props;
---
<span class={`inline-block ${className}`} aria-hidden="true">
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
  >
    <!-- Outer circle: the planet -->
    <circle cx="32" cy="32" r="28" stroke={color} stroke-width="1.5" />

    <!-- Equator -->
    <line x1="4" y1="32" x2="60" y2="32" stroke={color} stroke-width="1" />

    <!-- Tropics (curved horizontal lines, approximated as ellipses) -->
    <ellipse cx="32" cy="32" rx="28" ry="14" stroke={color} stroke-width="0.75" />
    <ellipse cx="32" cy="32" rx="28" ry="22" stroke={color} stroke-width="0.5" opacity="0.6" />

    <!-- Prime meridian -->
    <line x1="32" y1="4" x2="32" y2="60" stroke={color} stroke-width="1" />

    <!-- Other meridians (curved vertical lines as ellipses) -->
    <ellipse cx="32" cy="32" rx="14" ry="28" stroke={color} stroke-width="0.75" />
    <ellipse cx="32" cy="32" rx="22" ry="28" stroke={color} stroke-width="0.5" opacity="0.6" />

    <!-- Centre dot (Brahmasthan symbolism: the centre point) -->
    <circle cx="32" cy="32" r="1.5" fill={color} />
  </svg>
</span>
