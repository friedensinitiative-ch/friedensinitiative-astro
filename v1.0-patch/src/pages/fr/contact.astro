---
import PageLayout from '@layouts/PageLayout.astro';
import ContactForm from '@components/ContactForm.astro';
import { useTranslations } from '@i18n/index';

const locale = 'fr' as const;
const t = useTranslations(locale);
---
<PageLayout
  {locale}
  title={`${t('contact.hero.title')} – ${t('nav.contact')}`}
  description={t('contact.hero.subtitle')}
  route="contact"
>
  <section class="bg-gradient-to-b from-brand-parchment to-white">
    <div class="max-w-content mx-auto px-4 py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl mb-4">{t('contact.hero.title')}</h1>
      <p class="text-xl text-brand-gold-500 max-w-prose mx-auto">{t('contact.hero.subtitle')}</p>
    </div>
  </section>

  <div class="max-w-content mx-auto px-4 py-12">
    <div class="grid md:grid-cols-[2fr_1fr] gap-12">
      <div>
        <p class="text-base text-brand-ink-soft mb-6 max-w-prose">{t('contact.intro')}</p>
        <h2 class="text-2xl md:text-3xl mb-4 text-brand-gold-700">{t('contact.sendMessageTitle')}</h2>
        <ContactForm {locale} />
        <p class="mt-6 text-sm text-brand-ink-muted">{t('contact.responseTime')}</p>
      </div>

      <aside class="space-y-6 self-start">
        <div class="card-soft">
          <h2 class="text-xl mb-4">{t('contact.info.title')}</h2>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-brand-ink-muted uppercase tracking-wide text-xs mb-1">E-mail</dt>
              <dd>
                <a href={`mailto:${t('contact.info.email')}`} class="text-brand-gold-600 hover:text-brand-gold-700 underline">
                  {t('contact.info.email')}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-brand-ink-muted uppercase tracking-wide text-xs mb-1">Téléphone</dt>
              <dd>
                <a href={`tel:${t('contact.info.phone').replace(/\s/g, '')}`} class="text-brand-gold-600 hover:text-brand-gold-700">
                  {t('contact.info.phone')}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-brand-ink-muted uppercase tracking-wide text-xs mb-1">Adresse</dt>
              <dd>{t('contact.info.address')}</dd>
            </div>
          </dl>
        </div>

        <div class="card-soft">
          <h3 class="text-lg mb-3">{t('contact.officeHours.title')}</h3>
          <p class="text-sm text-brand-ink-soft">{t('contact.officeHours.line1')}</p>
          <p class="text-sm text-brand-ink-soft">{t('contact.officeHours.line2')}</p>
        </div>
      </aside>
    </div>
  </div>
</PageLayout>
