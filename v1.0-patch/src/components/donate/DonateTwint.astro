---
// TWINT donation — Mailchimp-style. Badge box on the left, QR on the right.
import { useTranslations, type Locale } from '@i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// RaiseNow link per locale
const raiseNowLinks: Record<Locale, string> = {
  de: 'https://donate.raisenow.io/pxmbx?lng=de',
  en: 'https://donate.raisenow.io/pxmbx?lng=en',
  fr: 'https://donate.raisenow.io/pxmbx?lng=fr',
};
---
<section class="my-12">
  <h2 class="text-center text-xl md:text-2xl font-semibold text-brand-gold-700 uppercase tracking-wide mb-6">
    {t('donate.twint.title')}
  </h2>

  <p class="text-base text-brand-ink-soft mb-8 max-w-3xl mx-auto">
    {t('donate.twint.intro')}
  </p>

  <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center max-w-3xl mx-auto">
    <div class="bg-white border border-brand-gold-100 rounded p-5">
      <div class="bg-brand-ink text-white inline-block px-4 py-2 rounded font-semibold mb-4">
        {t('donate.twint.badge')}
      </div>
      <ol class="space-y-3 text-sm">
        <li class="flex gap-3 items-start">
          <span aria-hidden="true" class="flex-shrink-0 text-brand-gold-500 mt-0.5">📱</span>
          <span>{t('donate.twint.step1')}</span>
        </li>
        <li class="flex gap-3 items-start">
          <span aria-hidden="true" class="flex-shrink-0 text-brand-gold-500 mt-0.5">✓</span>
          <span>{t('donate.twint.step2')}</span>
        </li>
      </ol>
    </div>

    <div class="flex justify-center">
      <img
        src="/uploads/twint-qr.png"
        alt="TWINT QR"
        width="180"
        height="180"
        loading="lazy"
        class="w-44 h-44 border border-brand-gold-100 rounded bg-white"
      />
    </div>
  </div>

  <p class="mt-6 text-center text-sm">
    <a href={raiseNowLinks[locale]} target="_blank" rel="noopener noreferrer"
       class="text-brand-gold-600 hover:text-brand-gold-700 underline">
      {t('donate.twint.fallbackLink')} →
    </a>
  </p>
</section>
