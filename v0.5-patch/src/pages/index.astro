---
// Auto-generated home page for locale: de
import PageLayout from '@layouts/PageLayout.astro';
import Hero from '@components/Hero.astro';
import TrainingSection from '@components/home/TrainingSection.astro';
import YogaSection from '@components/home/YogaSection.astro';
import YagyaSection from '@components/home/YagyaSection.astro';
import MediaSection from '@components/home/MediaSection.astro';
import { useTranslations } from '@i18n/index';

const locale = 'de' as const;
const t = useTranslations(locale);
---
<PageLayout
  {locale}
  title={`${t('hero.title').replace(/\{\{highlight\}\}|\{\{\/highlight\}\}/g, '')} – ${t('hero.subtitle')}`}
  description={t('hero.description')}
  route="home"
>
  <Hero {locale} />
  <TrainingSection {locale} />
  <YogaSection {locale} />
  <YagyaSection {locale} />
  <MediaSection {locale} />
</PageLayout>
